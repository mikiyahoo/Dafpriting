generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Starter models — replace with your own
// ─────────────────────────────────────────
// ADMIN USER
// ─────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // bcrypt hashed
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────
model Booking {
  id String @id @default(cuid())

  // Client info
  clientName  String
  clientEmail String
  clientPhone String

  // Event info
  eventType   EventType
  eventDate   DateTime
  location    String
  guestCount  Int?
  budgetRange BudgetRange
  notes       String?     @db.Text

  // Status
  status BookingStatus @default(NEW_REQUEST)

  // Internal
  internalNotes String? @db.Text
  assignedTo    String? // name of coordinator

  // Payment tracking
  agreedAmount  Float?
  depositAmount Float?
  depositPaid   Boolean   @default(false)
  depositDate   DateTime?
  balancePaid   Boolean   @default(false)
  balanceDate   DateTime?

  // Relations
  messages    Message[]
  invitations WeddingInvitation[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventType {
  WEDDING
  BIRTHDAY
  CORPORATE
  GRADUATION
  ENGAGEMENT
  ANNIVERSARY
  CULTURAL
  OTHER
}

enum BudgetRange {
  UNDER_50K // Under ETB 50,000
  RANGE_50K_100K // ETB 50,000 – 100,000
  RANGE_100K_200K // ETB 100,000 – 200,000
  RANGE_200K_500K // ETB 200,000 – 500,000
  ABOVE_500K // Above ETB 500,000
}

enum BookingStatus {
  NEW_REQUEST
  CONTACTED
  CONFIRMED
  PLANNED
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────
// MESSAGES (Client Communication Log)
// ─────────────────────────────────────────
model Message {
  id        String        @id @default(cuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender    MessageSender
  content   String        @db.Text
  createdAt DateTime      @default(now())
}

enum MessageSender {
  ADMIN
  SYSTEM // auto-generated status change messages
}

// ─────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────
model GalleryImage {
  id             String          @id @default(cuid())
  title          String
  description    String?
  imageUrl       String // Supabase Storage URL
  category       GalleryCategory
  isFeatured     Boolean         @default(false)
  isBeforeAfter  Boolean         @default(false)
  beforeImageUrl String? // only if isBeforeAfter = true
  afterImageUrl  String? // only if isBeforeAfter = true
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
}

enum GalleryCategory {
  WEDDINGS
  BIRTHDAYS
  CORPORATE
  DECORATIONS
  BEHIND_THE_SCENES
}

// ─────────────────────────────────────────
// SERVICE PACKAGES
// ─────────────────────────────────────────
model PackageCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packages Package[]
}

model Package {
  id String @id @default(cuid())

  categoryId String
  category   PackageCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  name        String
  shortDesc   String @default("")
  description String @db.Text

  price      Float?
  priceLabel String

  features   String[]
  exclusions String[] @default([])

  imageUrl      String?
  galleryImages String[] @default([])

  isPopular  Boolean @default(false)
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// WEDDING DIGITAL EXPERIENCE
model WeddingInvitation {
  id String @id @default(cuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  brideName String
  groomName String
  slug      String @unique

  weddingDate DateTime
  weddingTime String

  venueName    String
  venueAddress String
  dressCode    String?
  mapUrl       String?

  welcomeMessage String?  @db.Text
  story          String?  @db.Text
  heroImageUrl   String?
  coverImage     String?
  galleryImages  String[] @default([])

  templateKey    String          @default("FLORAL_LUXURY")
  theme          InvitationTheme @default(FLORAL_LUXURY)
  themeColor     String?
  primaryColor   String?
  secondaryColor String?
  customMessage  String?         @db.Text

  floralTopLeft     String?
  floralTopRight    String?
  floralBottomLeft  String?
  floralBottomRight String?

  status            InvitationStatus @default(DRAFT)
  allowRSVP         Boolean          @default(true)
  allowGiftRegistry Boolean          @default(true)
  publishedAt       DateTime?
  isPublished       Boolean          @default(false)
  pdfUrl            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gifts        GiftRegistry[]
  reservations GiftReservation[]
  rsvps        RSVP[]
}

model RSVP {
  id String @id @default(cuid())

  invitationId String
  invitation   WeddingInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  guestName  String
  guestPhone String?
  attendance RSVPStatus
  message    String?    @db.Text

  createdAt DateTime @default(now())
}

model GiftRegistry {
  id String @id @default(cuid())

  invitationId String
  invitation   WeddingInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  giftName        String
  title           String?
  description     String?
  imageUrl        String?
  priority        Int          @default(1)
  priorityLabel   GiftPriority @default(MEDIUM)
  allowDuplicates Boolean      @default(false)

  isReserved      Boolean @default(false)
  reservedBy      String?
  reservedMessage String?

  createdAt DateTime @default(now())

  reservations GiftReservation[]
}

model GiftReservation {
  id String @id @default(cuid())

  invitationId String
  invitation   WeddingInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  giftId String
  gift   GiftRegistry @relation(fields: [giftId], references: [id], onDelete: Cascade)

  reservedBy      String
  reservedMessage String?

  createdAt DateTime @default(now())
}

model DesignAsset {
  id        String        @id @default(cuid())
  name      String
  imageUrl  String
  category  AssetCategory
  createdAt DateTime      @default(now())
}

enum InvitationTheme {
  FLORAL_LUXURY
  MODERN_MINIMAL
  ROYAL_GOLD
  TRADITIONAL_ETHIOPIAN
  ELEGANT_BLACK
  GARDEN_WEDDING
  LUXURY_WHITE
  CLASSIC_SERIF
}

enum RSVPStatus {
  ATTENDING
  NOT_ATTENDING
  MAYBE
  ACCEPTED
  DECLINED
}

enum InvitationStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum GiftPriority {
  LOW
  MEDIUM
  HIGH
}

enum AssetCategory {
  FLORAL
  FRAME
  ORNAMENT
  TEXTURE
}
